{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and popup windows",
  "windows": ["main", "popup"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-open",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus"
  ]
}
